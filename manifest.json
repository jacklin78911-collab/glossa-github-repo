{
  "manifest_version": 3,
  "name": "Glossa",
  "version": "0.5.0",
  "description": "Parallel question cards for long-form reading with multiple web LLMs.",
  "permissions": ["storage", "sidePanel", "activeTab", "contextMenus", "tabs", "clipboardWrite", "clipboardRead"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open Glossa"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
